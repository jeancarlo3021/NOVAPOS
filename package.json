{
  "name": "novapos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "cd backend && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "vite build && cap sync",
    "android:add": "cap add android",
    "android:open": "vite build && cap sync && cap open android",
    "clean": "./cleanup.sh",
    "clean:all": "node cleanup-db.js",
    "clean:db": "node cleanup-db.js --db",
    "clean:reset": "node cleanup-db.js --reset",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:head": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:deps": "echo 'Fedora: instalá deps con: sudo dnf install -y nss nspr atk at-spi2-atk cups-libs libdrm libxkbcommon libXcomposite libXdamage libXfixes libXrandr mesa-libgbm libxshmfence alsa-lib pango cairo'"
  },
