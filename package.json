    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@sentry/react": "^8.55.2",
    "@supabase/supabase-js": "^2.103.0",
    "@types/jsbarcode": "^3.11.4",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.15.0",
    "date-fns": "^4.1.0",
    "idb": "^8.0.3",
    "jsbarcode": "^3.12.3",
    "konva": "^10.3.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.2.2",
